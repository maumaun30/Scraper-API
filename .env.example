# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/scraper_db

# JWT
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Scraper target
TARGET_URL=https://target-nextjs-site.com
SCRAPER_FIELD_SCHEMA=scraper_schema.json

# Scheduler (cron)
SCRAPE_CRON=0 */6 * * *   # every 6 hours

# Rate limiting
RATE_LIMIT=30/minute
