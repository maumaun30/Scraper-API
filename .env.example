# Database
# Inside docker compose, the host is `db` (service name), not localhost.
DATABASE_URL=postgresql+asyncpg://postgres:root@db:5432/scraper_db

# JWT
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Scheduler (cron) — every 6 hours
SCRAPE_CRON=0 */6 * * *

# Rate limiting
RATE_LIMIT=30/minute
