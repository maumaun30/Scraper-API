{
  "_comment": "Funalomax scraper schema. Each parent is a single page whose child categories are rendered as <section> blocks. Child category labels come from each section header. We skip the 'Recommendation' section by default (it's a curation banner, not a real category).",

  "sections": [
    {
      "id": "perya",
      "label": "Perya",
      "url": "https://funalomax.com/en/perya"
    },
    {
      "id": "casino",
      "label": "Casino",
      "url": "https://funalomax.com/en/casino"
    },
    {
      "id": "slot",
      "label": "Slot",
      "url": "https://funalomax.com/en/slots"
    },
    {
      "id": "e-game",
      "label": "E-Game",
      "url": "https://funalomax.com/en/e-game"
    }
  ],

  "selectors": {
    "disclaimer_proceed_button": "div[role='dialog'] button:has-text('Proceed')",
    "child_category_section": "section:has(span.text-primary.font-semibold)",
    "child_category_label": "span.text-primary.font-semibold",
    "game_card": "div.relative.w-full.rounded-lg",
    "game_image": "img[alt]"
  },

  "skip_child_categories": ["Recommendation"]
}
